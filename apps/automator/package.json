{
  "name": "@insta-puppeteer/automator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "format": "biome format",
    "lint": "biome lint",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@insta-puppeteer/database": "workspace:*",
    "dotenv": "^17.2.1",
    "express": "^5.2.1",
    "puppeteer": "^24.16.1"
  },
  "devDependencies": {
    "@insta-puppeteer/biome-config": "workspace:^",
    "@insta-puppeteer/ts-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^25",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
