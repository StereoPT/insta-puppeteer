{
  "name": "@insta-puppeteer/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "pnpm db:generate && tsc",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@insta-puppeteer/biome-config": "workspace:^",
    "@insta-puppeteer/ts-config": "workspace:*",
    "@types/node": "^25",
    "prisma": "^7.4.0",
    "typescript": "^5.9.3"
  }
}
