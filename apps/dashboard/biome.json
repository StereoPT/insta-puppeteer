{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "root": false,
  "extends": [
    "@insta-puppeteer/biome-config/base",
    "@insta-puppeteer/biome-config/next"
  ],
  "files": {
    "ignoreUnknown": false,
    "includes": ["!src/components/ui"]
  },
  "overrides": [
    {
      "includes": ["src/app/not-found.tsx", "src/hooks/use-mobile.ts"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
