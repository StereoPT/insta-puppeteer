{
  "name": "insta-puppeteer",
  "version": "4.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:automator": "turbo run dev --filter=@insta-puppeteer/automator",
    "dev:dashboard": "turbo run dev --filter=@insta-puppeteer/dashboard",
    "format": "turbo format --continue --",
    "format:fix": "turbo format --continue -- --write",
    "lint": "turbo lint --continue --",
    "lint:fix": "turbo lint --continue -- --write",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@insta-puppeteer/database",
    "db:migrate": "turbo run db:migrate --filter=@insta-puppeteer/database --",
    "shadcn": "turbo run shadcn --filter=@insta-puppeteer/ui --",
    "shadcn:add": "turbo run shadcn:add --filter=@insta-puppeteer/ui --"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18"
  }
}
