{
  "name": "@insta-puppeteer/automator",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'tsx' src/main.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "format": "biome format",
    "lint": "biome lint",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@insta-puppeteer/database": "workspace:*",
    "dotenv": "^17.2.1",
    "puppeteer": "^24.16.1"
  },
  "devDependencies": {
    "@insta-puppeteer/biome-config": "workspace:^",
    "@insta-puppeteer/ts-config": "workspace:*",
    "@types/node": "^25",
    "nodemon": "^3.1.14",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
